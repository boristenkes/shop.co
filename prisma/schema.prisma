// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum UserRole {
  customer
  admin
}

enum ProductSize {
  XS
  S
  M
  L
  XL
  XXL
  XXXL
}

type Image {
  url String
  key String
}

model User {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  role          UserRole  @default(customer)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Account {
  id                String  @id @default(auto()) @map("_id") @db.ObjectId
  userId            String  @db.ObjectId
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @map("refreshToken") @db.String
  access_token      String? @map("accessToken") @db.String
  expires_at        Int?    @map("expiresAt")
  token_type        String? @map("tokenType")
  scope             String?
  id_token          String? @map("idToken") @db.String
  session_state     String? @map("sessionState")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  sessionToken String   @unique
  userId       String   @db.ObjectId
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("sessions")
}

model VerificationToken {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verificationTokens")
}

model Category {
  id   String @id @default(auto()) @map("_id") @db.ObjectId
  name String

  @@map("categories")
}

model Color {
  id   String @id @default(auto()) @map("_id") @db.ObjectId
  name String
  hex  String

  @@map("colors")
}

model Product {
  id           String        @id @default(auto()) @map("_id") @db.ObjectId
  name         String
  priceInCents Int
  description  String?
  stock        Int
  featured     Boolean       @default(false)
  archived     Boolean       @default(false)
  discount     Int
  sizes        ProductSize[]
  categories   String[]      @db.ObjectId
  colors       String[]      @db.ObjectId
  images       Image[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("products")
}

model Order {
  id   String @id @default(auto()) @map("_id") @db.ObjectId
  user String @db.ObjectId

  orderItems String[] @db.ObjectId

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("orders")
}

model OrderItem {
  id       String @id @default(auto()) @map("_id") @db.ObjectId
  quantity Int    @default(1)

  orderId String      @db.ObjectId
  product String      @db.ObjectId
  color   String      @db.ObjectId
  size    ProductSize

  @@map("orderItems")
}

model Review {
  id      String @id @default(auto()) @map("_id") @db.ObjectId
  rating  Float
  comment String

  productId String @db.ObjectId
  user      String @db.ObjectId

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("reviews")
}
